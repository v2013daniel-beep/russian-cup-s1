generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tournament {
  id              String   @id @default(cuid())
  name            String   @default("RUSSIAN CUP SEASON 1")
  date            DateTime @default("2024-08-15T18:00:00.000Z")
  prizePool       String   @default("250 000 ₽")
  entryFee        Int      @default(5000)
  format          String   @default("5x5")
  server          String   @default("EU / RU")
  registrationOpen Boolean @default(true)
  contacts        Contact?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Contact {
  id           String     @id @default(cuid())
  tournamentId String     @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  discord      String     @default("https://discord.gg/russiancup")
  telegram     String     @default("https://t.me/russiancup_admin")
  email        String     @default("admin@russiancup.ru")
  responseTime String     @default("Ежедневно с 10:00 до 22:00 (MSK)")
}

model Team {
  id            String    @id @default(cuid())
  teamName      String
  teamTag       String
  playerCount   Int       @default(5)
  substitute    String?
  captainName   String
  captainNickname String
  captainTelegram String
  captainDiscord  String
  captainEmail    String
  players       Player[]
  status        String    @default("pending")
  payment       Payment?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Player {
  id        String @id @default(cuid())
  teamId    String
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  nickname  String
  mmr       String
  dotabuff  String
  steam     String
  order     Int
}

model Payment {
  id            String   @id @default(cuid())
  teamId        String   @unique
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  amount        Int
  method        String   @default("robokassa")
  status        String   @default("pending")
  externalId    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique @default("admin")
  password  String
  createdAt DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  ip        String?
  userAgent String?
}

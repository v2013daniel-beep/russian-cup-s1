# Database
# For local development / VPS:
DATABASE_URL="file:./dev.db"
# For Vercel + PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Admin
ADMIN_PASSWORD="admin123"

# JWT Secret (min 32 chars, required for production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"

# Robokassa
ROBOKASSA_MERCHANT_LOGIN="your_robokassa_login"
ROBOKASSA_PASSWORD_1="your_password_1"
ROBOKASSA_PASSWORD_2="your_password_2"
ROBOKASSA_TEST_MODE="1"

# Telegram notifications
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_ADMIN_CHAT_ID="your_chat_id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
